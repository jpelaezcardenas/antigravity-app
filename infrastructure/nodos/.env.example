# Nodos Contexia — Per-node environment variables
# Copy to .env.node and fill in values before `docker compose up`

# --- n8n ---
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678/
# Required: generate with `openssl rand -base64 32`
N8N_ENCRYPTION_KEY=

# --- Central API connection ---
CONTEXIA_API_URL=https://api.contexia.online/api/v1
# Per-node client identifier (e.g., "node-envigado-001")
CONTEXIA_CLIENT_ID=node-envigado-001

# --- NAS (Minio) ---
NAS_ACCESS_KEY=contexianodos
# Required: at least 8 chars, alphanumeric
NAS_SECRET_KEY=
