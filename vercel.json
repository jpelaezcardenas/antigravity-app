{
    "name": "contexia-web-app",
    "version": 2,
    "redirects": [
        {
            "source": "/",
            "destination": "/landing.html",
            "permanent": false
        },
        {
            "source": "/app",
            "destination": "/app/overview",
            "permanent": false
        },
        {
            "source": "/login",
            "destination": "/app/overview",
            "permanent": true
        },
        {
            "source": "/bunker",
            "destination": "/bunker/",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/crear-empresa-wizard",
            "destination": "/crear-empresa-wizard.html"
        },
        {
            "source": "/bunker/:path*",
            "destination": "/app/"
        },
        {
            "source": "/bunker",
            "destination": "/app/"
        },
        {
            "source": "/app/_next/:path*",
            "destination": "https://contexia-app.vercel.app/_next/:path*"
        },
        {
            "source": "/app/:path*",
            "destination": "https://contexia-app.vercel.app/app/:path*"
        },
        {
            "source": "/wizard/api/:path*",
            "destination": "https://contexia-wizard.vercel.app/wizard/api/:path*/"
        },
        {
            "source": "/wizard/:path*",
            "destination": "https://contexia-wizard.vercel.app/wizard/:path*"
        },
        {
            "source": "/wizard",
            "destination": "https://contexia-wizard.vercel.app/wizard"
        }
    ]
}
