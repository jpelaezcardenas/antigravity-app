{
    "name": "contexia-web-app",
    "version": 2,
    "outputDirectory": ".",
    "redirects": [
        {
            "source": "/",
            "destination": "/landing.html",
            "permanent": false
        },
        {
            "source": "/login",
            "destination": "/login.html",
            "permanent": false
        },
        {
            "source": "/app/login",
            "destination": "/login.html",
            "permanent": false
        },
        {
            "source": "/app/login.html",
            "destination": "/login.html",
            "permanent": false
        },
        {
            "source": "/wizard/login",
            "destination": "/login.html",
            "permanent": false
        },
        {
            "source": "/wizard/login/",
            "destination": "/login.html",
            "permanent": false
        },
        {
            "source": "/wizard/dashboard",
            "destination": "/login.html",
            "permanent": false
        },
        {
            "source": "/wizard/dashboard/",
            "destination": "/login.html",
            "permanent": false
        },
        {
            "source": "/wizard/",
            "destination": "/wizard",
            "permanent": false
        },
        {
            "source": "/logout",
            "destination": "/logout.html",
            "permanent": false
        }
    ],
    "headers": [
        {
            "source": "/app/:path*",
            "headers": [
                { "key": "Cache-Control", "value": "private, no-store, max-age=0, s-maxage=0, must-revalidate" },
                { "key": "CDN-Cache-Control", "value": "no-store" },
                { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
            ]
        },
        {
            "source": "/app-admin/:path*",
            "headers": [
                { "key": "Cache-Control", "value": "private, no-store, max-age=0, s-maxage=0, must-revalidate" },
                { "key": "CDN-Cache-Control", "value": "no-store" },
                { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/app",
            "destination": "/app-admin/index.html"
        },
        {
            "source": "/app/overview",
            "destination": "/app/overview.html"
        },
        {
            "source": "/app/fiscal",
            "destination": "/app/fiscal.html"
        },
        {
            "source": "/app/radar",
            "destination": "/app/radar.html"
        },
        {
            "source": "/app/patrimonio",
            "destination": "/app/patrimonio.html"
        },
        {
            "source": "/app/config",
            "destination": "/app/config.html"
        },
        {
            "source": "/flujo-detalle",
            "destination": "/app/flujo-detalle.html"
        },
        {
            "source": "/app/flujo-detalle",
            "destination": "/app/flujo-detalle.html"
        },
        {
            "source": "/app/bunker",
            "destination": "/app-admin/index.html"
        },
        {
            "source": "/app/dashboard-assets/:path*",
            "destination": "/app-admin/dashboard-assets/:path*"
        },
        {
            "source": "/_next/:path*",
            "destination": "/_next/:path*"
        },
        {
            "source": "/app/:path*",
            "destination": "/app-admin/index.html"
        },
        {
            "source": "/crear-empresa",
            "destination": "/crear-empresa.html"
        },
        {
            "source": "/crear-empresa-wizard",
            "destination": "/crear-empresa-wizard.html"
        },
        {
            "source": "/app/assets/:path*",
            "destination": "/app/assets/:path*"
        },
        {
            "source": "/wizard/api/:path*",
            "destination": "https://contexia-wizard.vercel.app/wizard/api/:path*"
        },
        {
            "source": "/wizard/:path*",
            "destination": "https://contexia-wizard.vercel.app/wizard/:path*"
        },
        {
            "source": "/wizard",
            "destination": "https://contexia-wizard.vercel.app/wizard"
        }
    ]
}
