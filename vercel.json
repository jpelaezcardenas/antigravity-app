{
    "name": "contexia-monolith",
    "version": 2,
    "buildCommand": "cd frontend/dashboard && npm run build",
    "outputDirectory": "frontend/dashboard/dist",
    "installCommand": "npm install && cd frontend/dashboard && npm install && cd ../wizard && npm install",
    "env": {
        "VITE_SUPABASE_URL": "@supabase_url",
        "VITE_SUPABASE_ANON_KEY": "@supabase_anon_key",
        "REACT_APP_GEMINI_API_KEY": "@gemini_api_key"
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "http://localhost:8080/api/:path*"
        },
        {
            "source": "/:path*",
            "destination": "/index.html"
        }
    ],
    "cleanUrls": true,
    "trailingSlash": false
}
