# Vaultwarden Environment Variables (Fase 2)
# Copy this file to .env.vaultwarden and fill in actual values

# Admin panel token (generate with: openssl rand -base64 32)
ADMIN_TOKEN=

# PostgreSQL (for production)
POSTGRES_PASSWORD=

# SMTP (Resend for emails)
RESEND_API_KEY=

# AWS S3 (backup, optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# FastAPI backend integration
SECRETS_BACKEND=vaultwarden
BW_CLIENT_ID=
BW_CLIENT_SECRET=
BW_VAULT_URL=http://vaultwarden:80
