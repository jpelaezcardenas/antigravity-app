{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--reload"],
      "port": 8080
    },
    {
      "name": "Frontend Dashboard (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend/dashboard", "run", "dev"],
      "port": 5173
    },
    {
      "name": "Contexia Wizard (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "contexia-wizard", "run", "dev"],
      "port": 3000
    },
    {
      "name": "Contexia App (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "contexia-app", "run", "dev"],
      "port": 3001
    },
    {
      "name": "Contexia Dashboard (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "Contexia_Daschboard", "run", "dev"],
      "port": 3002
    }
  ]
}
