{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI / uvicorn)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--reload", "--app-dir", "apps/backend", "--port", "8080"],
      "port": 8080
    },
    {
      "name": "Contexia Wizard (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "contexia-wizard", "run", "dev"],
      "port": 3000
    },
    {
      "name": "Frontend Dashboard (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend/dashboard", "run", "dev"],
      "port": 5173
    }
  ]
}
