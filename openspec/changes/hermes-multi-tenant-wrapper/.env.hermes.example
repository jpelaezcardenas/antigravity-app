# Hermes Multi-Tenant Configuration Template
# Location: ~/.hermes/.env (inside WSL hermes-ws distro)
# Copy to: ~/.hermes/.env and fill in values
# Date: 2026-06-29

# ============================================================================
# TENANT CONTEXT (Required)
# ============================================================================

# Which organization this Hermes instance serves
# Format: kebab-case org identifier
# Examples: contexia-org-1, client-xyz, client-abc
HERMES_TENANT_ID=contexia-org-1

# Human-readable organization name (for logs and UI)
HERMES_ORG_NAME="Contexia S.A.S."

# ============================================================================
# API CONNECTIVITY (Required)
# ============================================================================

# Railway backend API endpoint
# Local development: http://127.0.0.1:8080/api/v1
# Production: https://antigravity-app-production-175a.up.railway.app/api/v1
HERMES_API_URL=http://127.0.0.1:8080/api/v1

# Hermes gateway port (WebSocket, skill invocations)
# Default: 8642
HERMES_GATEWAY_PORT=8642

# Hermes Workspace UI port (web interface)
# Default: 3000
HERMES_WORKSPACE_PORT=3000

# ============================================================================
# AUTHENTICATION (Required)
# ============================================================================

# JWT secret for signing tokens issued by Hermes
# Option A: Set directly (for development)
#   HERMES_JWT_SECRET=dev-secret-change-in-production
#
# Option B: Read from Bitwarden (recommended for production)
#   HERMES_JWT_SECRET=$(bw get item contexia | jq -r '.fields[] | select(.name=="JWT_SECRET") | .value')
#
# Option C: Read from Railway env
#   HERMES_JWT_SECRET=$(railway env | grep JWT_SECRET | cut -d= -f2)
#
# Must be 32+ characters for production
HERMES_JWT_SECRET=dev-secret-hermes-change-in-production

# JWT tenant claim name (must match Railway backend)
# This is the field name in the JWT payload that Hermes reads to determine tenant_id
# Standard: "tenant_id"
HERMES_JWT_TENANT_CLAIM=tenant_id

# JWT algorithm
# Supported: HS256 (symmetric), RS256 (asymmetric)
HERMES_JWT_ALGORITHM=HS256

# JWT expiration (minutes)
# Default: 30 (tokens refresh frequently during long missions)
HERMES_JWT_EXPIRE_MINUTES=30

# ============================================================================
# FEATURES & BEHAVIOR (Optional)
# ============================================================================

# Auto-detect gateway URL from hostname
# Set to false if behind proxy/tunnel or manual setup
HERMES_AUTO_DETECT=false

# Log level: debug, info, warning, error
# Default: info
# Use debug for troubleshooting, info for production
HERMES_LOG_LEVEL=info

# Enable Hermes Gateway as systemd service (auto-restart on boot)
# Linux/WSL only; requires sudo to set up
HERMES_ENABLE_SERVICE=true

# Service name (if systemd enabled)
HERMES_SERVICE_NAME=hermes-gateway.service

# ============================================================================
# OPERATORS (Optional: Configure Individual Agents)
# ============================================================================

# Comma-separated list of enabled operators
# Operators not in this list will be disabled
# Default: all (empty = all enabled)
HERMES_ENABLED_OPERATORS=Pulso,Centinela,Radar,Auditoria,Taty,ContentOps,SocialOps,Metrics,Maestro

# Per-operator overrides (optional, advanced)
# Format: HERMES_OPERATOR_[NAME]_[SETTING]=value
# Examples:
#   HERMES_OPERATOR_PULSO_MODEL=gemini-2.5-flash
#   HERMES_OPERATOR_CENTINELA_TIMEOUT=60
#   HERMES_OPERATOR_MAESTRO_WORKERS=4

# ============================================================================
# WORKSPACE UI (Optional)
# ============================================================================

# Workspace UI theme
# Options: light, dark, auto (follows system)
HERMES_WORKSPACE_THEME=auto

# Workspace UI language
# Options: en, es
HERMES_WORKSPACE_LANGUAGE=es

# ============================================================================
# DEBUGGING & DIAGNOSTICS (Optional)
# ============================================================================

# Enable verbose request/response logging
# Warning: May expose sensitive data; only for troubleshooting
HERMES_DEBUG_REQUESTS=false

# Enable profiling (measures performance of operators)
HERMES_ENABLE_PROFILING=false

# Metrics port (for Prometheus-style monitoring)
# Default: 9090
HERMES_METRICS_PORT=9090

# ============================================================================
# SECURITY (Optional but Recommended for Production)
# ============================================================================

# Enable HTTPS for gateway (requires certificate)
# Options: true, false
HERMES_ENABLE_TLS=false

# TLS certificate path (if HERMES_ENABLE_TLS=true)
# Format: /path/to/cert.pem
HERMES_TLS_CERT_PATH=/etc/ssl/certs/hermes.pem

# TLS key path (if HERMES_ENABLE_TLS=true)
HERMES_TLS_KEY_PATH=/etc/ssl/private/hermes.key

# Enable request signature verification
# Requires all requests to include valid JWT signature
HERMES_VERIFY_SIGNATURES=true

# Rate limit (requests per second)
# Default: unlimited (-1)
HERMES_RATE_LIMIT=-1

# ============================================================================
# INTEGRATION: Telegram Bot (Optional, for Taty agent)
# ============================================================================

# Telegram bot token (for Taty operator)
# Get from: @BotFather on Telegram
# Store in Bitwarden: Contexia/Operations/Telegram-Bot-Token
HERMES_TELEGRAM_BOT_TOKEN=$(bw get item contexia | jq -r '.fields[] | select(.name=="Telegram-Bot-Token") | .value' 2>/dev/null)

# ============================================================================
# INTEGRATION: DIAN / ERP Systems (Optional, for Phase 2)
# ============================================================================

# SyncManager API endpoint (Phase 2)
# Will be populated during SyncManager integration (Jul 3-31)
# HERMES_SYNCMANAGER_URL=https://api.syncmanager.com

# Shadow GL database (Phase 2b)
# Local PostgreSQL instance for deterministic GL backup
# HERMES_SHADOW_GL_DATABASE_URL=postgresql://user:password@localhost/shadow_gl

# ============================================================================
# QUICK START
# ============================================================================

# 1. Copy this file to ~/.hermes/.env
#    cp .env.hermes.example ~/.hermes/.env
#
# 2. Edit values (especially HERMES_JWT_SECRET and HERMES_API_URL)
#    nano ~/.hermes/.env
#
# 3. Source the file in your shell
#    source ~/.hermes/.env
#
# 4. Verify configuration
#    echo "Tenant: $HERMES_TENANT_ID"
#    echo "Backend: $HERMES_API_URL"
#    echo "Gateway port: $HERMES_GATEWAY_PORT"
#
# 5. Start Hermes gateway
#    hermes -p contexia gateway run
#
# 6. Start Hermes Workspace (in another terminal)
#    hermes -p contexia workspace run
#
# 7. Open Workspace UI
#    open http://localhost:3000
#
# 8. Test operator call
#    - Create mission: "Pulso: daily summary"
#    - Click: Operators → Pulso → Execute
#    - Check backend logs for [Tenant: contexia-org-1]

# ============================================================================
# TROUBLESHOOTING
# ============================================================================

# Problem: "Connection refused" to Railway backend
# Solution: Ensure HERMES_API_URL is correct and backend is running
#   curl $HERMES_API_URL/health
#
# Problem: "Unauthorized" (401) on operator call
# Solution: Verify HERMES_JWT_SECRET matches Railway JWT_SECRET
#   bw get item contexia | jq '.fields[] | select(.name=="JWT_SECRET")'
#
# Problem: "No data returned" from operator
# Solution: Check RLS policies in Supabase dashboard
#   - Table: public.pulso_results
#   - Check: Policies tab
#   - Should see: pulso_results_tenant_isolation
#
# Problem: Workspace shows "Welcome! Connect backend"
# Solution: Set HERMES_AUTO_DETECT=false and explicit URLs
#   export HERMES_AUTO_DETECT=false
#   hermes -p contexia workspace run

# ============================================================================
