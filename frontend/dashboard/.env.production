# Production environment variables for Contexia PWA

# WebSocket endpoint for Hermes agents
VITE_WS_URL=wss://antigravity-app-production-175a.up.railway.app/api/v1/ws

# API base URL
VITE_API_URL=https://antigravity-app-production-175a.up.railway.app/api/v1

# Application name
VITE_APP_NAME=Contexia

# Debug mode (false in production)
VITE_DEBUG=false
