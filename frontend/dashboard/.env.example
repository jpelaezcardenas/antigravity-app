# Frontend Dashboard Environment Variables

# Sentry Error Tracking (Stage 3)
# Get DSN from https://sentry.io/projects/
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# WebSocket Configuration (Phase 5)
VITE_WS_URL=wss://antigravity-app-production-175a.up.railway.app/api/v1/ws

# App Version (for Sentry release tracking)
VITE_APP_VERSION=1.0.0

# Environment
NODE_ENV=development
