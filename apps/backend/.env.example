# ============================================
# CONTEXIA BACKEND - Cloud-Only Configuration
# ============================================

# Supabase (Database & Auth)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJxxxxx
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# JWT (Authentication)
JWT_SECRET=cambiar_por_secret_aleatorio_minimo_32_caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Environment
ENVIRONMENT=development
DEBUG=True

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://contexia.online,https://app.contexia.online

# ============================================
# LLM PROVIDERS - Cloud-Only Failover Chain
# ============================================
# Arquitectura: Tier 1/2 → OpenRouter Free (gratis)
#              Tier 3 → Groq (crítico, pagado)
#              Fallback chain completa para redundancia

# OpenRouter Free API (REQUERIDO - Tier 1 & 2)
# Obtén en: https://openrouter.ai/keys
# ~100 req/día sin autenticación (gratis)
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXX

# Groq (REQUERIDO - Tier 3 Critical, fallback)
# Obtén en: https://console.groq.com
# Modelos: llama-3.3-70b-versatile
GROQ_API_KEY=gsk_XXXXXXXX

# Claude (Opcional - Desarrollo & fallback crítico)
# Obtén en: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-XXXXXXXX

# Alternativas de Fallback (opcional si quieres más redundancia)
# CEREBRAS_API_KEY=XXXXXXXX
# MISTRAL_API_KEY=XXXXXXXX
# GEMINI_API_KEY=XXXXXXXX

# ============================================
# TELEGRAM BOT - Taty Contadora Channel
# ============================================
# Crear bot con BotFather: https://t.me/botfather
# Obtén token y guárdalo en TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_TOKEN=XXXXXXXX
TELEGRAM_WEBHOOK_URL=https://antigravity-app-production-175a.up.railway.app/api/v1/channels/telegram/webhook
