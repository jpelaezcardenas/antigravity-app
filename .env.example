# Secrets Provider Configuration (Keeper → Bitwarden Migration)
# Date: 2026-06-15
# Owner: Infra Team
#
# IMPORTANT:
# - Copy this file to .env.local
# - Fill in ONLY LOCALLY, never commit .env.local
# - All sensitive values MUST be stored in Bitwarden vault
#   Location: Contexia workspace → Zona CONTEXIA /Infraestructura folder
#   Items: "Bitwarden API Keys", "Bitwarden Master Password"
# - Extract values from Bitwarden using: bw get item <name>

# ============================================================================
# BITWARDEN CLOUD (Phase 1)
# ============================================================================

# Bitwarden Vault URL (public)
BW_VAULT_URL=https://vault.bitwarden.com

# Bitwarden Organization API Credentials
# Store in Bitwarden: "Bitwarden API Keys"
# Extract: bw get item "Bitwarden API Keys" | jq -r '.login.username'
BW_CLIENT_ID=REPLACE_WITH_VALUE_FROM_BITWARDEN

# Extract: bw get item "Bitwarden API Keys" | jq -r '.login.password'
BW_CLIENT_SECRET=REPLACE_WITH_VALUE_FROM_BITWARDEN

# Bitwarden Master Password (for organization unlock)
# Store in Bitwarden: "Bitwarden Master Password"
# Extract: bw get item "Bitwarden Master Password" | jq -r '.login.password'
BW_MASTER_PASSWORD=REPLACE_WITH_VALUE_FROM_BITWARDEN

# ============================================================================
# SECRETS PROVIDER BACKEND
# ============================================================================

# Which backend to use: bitwarden | vaultwarden
SECRETS_BACKEND=bitwarden

# Session token (if using bw CLI directly)
# Generate: bw login jpelaezcardenas@gmail.com && bw unlock
# Set: export BW_SESSION="<token>"
BW_SESSION=REPLACE_IF_NEEDED

# ============================================================================
# RAILWAY DEPLOYMENT
# ============================================================================

# Railway project token (for deployments)
# Store in Bitwarden: "Railway API Token"
RAILWAY_API_TOKEN=REPLACE_WITH_VALUE_FROM_BITWARDEN

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

LOG_LEVEL=info
DEBUG=false

# ============================================================================
# PHASE 2 (Vaultwarden Self-Hosted) - Deferred until 2026-07-04
# ============================================================================
# VW_ADMIN_TOKEN=REPLACE_WHEN_PHASE_2_STARTS
# VW_DB_URL=REPLACE_WHEN_PHASE_2_STARTS
# VW_SMTP_HOST=REPLACE_WHEN_PHASE_2_STARTS
