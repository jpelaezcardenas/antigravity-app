    {
      "parameters": {
        "jsCode": "try {\n  const inputData = $input.all();\n  if (Array.isArray(inputData) && inputData.length > 0 && inputData[0].json && !inputData[0].json.text) {\n    const firstItem = inputData[0].json;\n    if (Array.isArray(firstItem)) {\n      return firstItem.map(idea => ({ json: idea }));\n    } else if (firstItem.tema || firstItem.pilar) {\n      return inputData;\n    }\n  }\n  const rawText = $input.first().json.text || JSON.stringify($input.first().json);\n  const cleanText = rawText.replace(/```json/g, '').replace(/```/g, '').trim();\n  const ideas = JSON.parse(cleanText);\n  return ideas.map(idea => ({ json: idea }));\n} catch (e) {\n  return $input.all();\n}"
      },
